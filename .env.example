# ──────────────────────────────────────────────────────────────────────
# SOCOPAD — Variables d'environnement (modèle)
# Copier ce fichier vers `.env` puis ajuster.
# Pour la production, voir aussi DEPLOIEMENT.md
# ──────────────────────────────────────────────────────────────────────

# ─── Base de données ──────────────────────────────────────────────────
# Dev local : SQLite (aucun service à lancer)
DATABASE_URL="file:./dev.db"

# Prod / Supabase / Postgres managé : décommenter et remplir.
# Format : postgres://USER:PASSWORD@HOST:PORT/DBNAME?schema=public&sslmode=require
# Pour Supabase, prendre la "Connection pooling" URL en mode "Transaction"
# (port 6543) car les routes serverless ouvrent/ferment des connexions.
# DATABASE_URL="postgres://postgres.<ref>:<password>@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ─── NextAuth.js ──────────────────────────────────────────────────────
# Secret de signature JWT — OBLIGATOIRE en production.
# Générer avec : openssl rand -base64 32   (Linux/Mac)
# ou avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="changez-moi-en-production-via-un-secret-fort"

# URL canonique de l'app (pas de slash final).
# Dev local : http://localhost:3000
# Prod : https://votre-domaine.vercel.app  (ou domaine custom)
AUTH_URL="http://localhost:3000"

# ─── Paramètres applicatifs ───────────────────────────────────────────
# NODE_ENV est défini automatiquement par Next.js — ne pas y toucher en prod.
NEXT_PUBLIC_APP_NAME="SOCOPAD"
NEXT_PUBLIC_APP_LOCALE="fr-CI"
